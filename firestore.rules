rules_version = '2';

// VigApp Firestore security rules — email allowlist.
//
// Access is controlled purely by the `allowed_emails` collection (managed from
// the in-app "Controle de Acesso" page). Only e-mails on that list can
// read/write the business data. No `users` collection or admin role required.
//
// BOOTSTRAP (do this so you don't lock yourself out):
//   Option A (no console editing): while the default/open rules are still
//     active, open the app → Controle de Acesso → add your team's e-mails
//     (INCLUDING YOUR OWN). Then publish these rules.
//   Option B: publish these rules first, then in Firestore create one document
//     in the `allowed_emails` collection with the Document ID = your e-mail
//     (lowercase) and a field `email` = the same e-mail. Then add the rest from
//     inside the app.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function userEmail() { return request.auth.token.email; }

    // The allowlist doc id is the lowercased e-mail (see src/pages/access.js).
    function isAllowlisted() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/allowed_emails/$(userEmail()));
    }

    // Allowlist: any signed-in user can READ it (the login gate checks
    // membership); allowlisted users can add/remove e-mails.
    match /allowed_emails/{emailId} {
      allow read: if isSignedIn();
      allow write: if isAllowlisted();
    }

    // Optional user profiles (created on login): a user manages only their own.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // All business data: only allowlisted users.
    match /{col}/{docId} {
      allow read, write: if isAllowlisted() && !(col in ['users', 'allowed_emails']);
    }
  }
}
